generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// RBAC Dinámico y Autenticación
// ==========================================

model Rol {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique // Ej. "Director", "Servicios Escolares", "Docente", "Alumno"
  descripcion String?
  permisos    Permiso[]
  usuarios    Usuario[]
  creadoEn    DateTime  @default(now())
}

model Permiso {
  id     Int    @id @default(autoincrement())
  nombre String @unique // Ej. "crear_grupo", "ver_metricas", "gestionar_docentes"
  roles  Rol[]
}

model Usuario {
  id             Int     @id @default(autoincrement())
  email          String  @unique
  passwordHash   String
  nombreCompleto String
  estatus        Boolean @default(true)

  rolId Int
  rol   Rol @relation(fields: [rolId], references: [id])

  // Perfiles específicos (opcionales dependiendo del rol)
  docenteId Int?     @unique
  docente   Docente? @relation(fields: [docenteId], references: [id])

  alumnoId Int?    @unique
  alumno   Alumno? @relation(fields: [alumnoId], references: [id])

  tutorId Int?   @unique
  tutor   Tutor? @relation(fields: [tutorId], references: [id])

  notificaciones Notificacion[]

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

// ==========================================
// Estructura Académica (Generaciones y Grupos)
// ==========================================

model Generacion {
  id       Int      @id @default(autoincrement())
  nombre   String   @unique // Ej. "Semestre 1", "tprog 2024-2027"
  activa   Boolean  @default(true) // False si ya egresaron
  grupos   Grupo[]
  alumnos  Alumno[]
  creadoEn DateTime @default(now())
}

model Grupo {
  id             Int            @id @default(autoincrement())
  nombre         String         @unique
  turno          String
  numeroMaterias Int            @default(0)
  generacionId   Int?
  generacion     Generacion?    @relation(fields: [generacionId], references: [id])
  alumnos        Alumno[]
  docenteGrupos  GrupoDocente[]
  tareas         Tarea[]
  creadoEn       DateTime       @default(now())
  actualizadoEn  DateTime       @updatedAt
}

// ==========================================
// Perfiles de Usuarios
// ==========================================

model Docente {
  id             Int              @id @default(autoincrement())
  nombres        String
  apellidos      String
  numeroEmpleado String           @unique
  telefono       String?
  usuario        Usuario?
  grupos         GrupoDocente[]
  bitacoras      BitacoraAcceso[]
  tareas         Tarea[]
}

model Alumno {
  id                         Int     @id @default(autoincrement())
  matricula                  String  @unique
  correo                     String? @unique
  nombres                    String
  apellidos                  String?
  apellidoPaterno            String  @default("")
  apellidoMaterno            String  @default("")
  turno                      String  @default("Matutino")
  grupo                      String?
  numeroLista                Int     @default(1)
  edad                       Int?
  faltas                     Int     @default(0)
  telefono                   String?
  direccion                  String?
  estatus                    String  @default("Inscrito")
  observaciones              String?
  contactoEmergenciaNombre   String?
  contactoEmergenciaTelefono String?

  generacionId   Int?
  generacion     Generacion?    @relation(fields: [generacionId], references: [id])
  grupoId        Int?
  grupoRel       Grupo?         @relation(fields: [grupoId], references: [id])
  usuario        Usuario?
  tutores        TutorAlumno[]
  asistencias    Asistencia[]
  calificaciones Calificacion[]
  tramites       Tramite[]
  entregasTarea  EntregaTarea[]
  citaTutors     CitaTutor[]
}

model Tutor {
  id         Int           @id @default(autoincrement())
  nombres    String
  apellidos  String
  telefono   String?
  usuario    Usuario?
  alumnos    TutorAlumno[]
  citaTutors CitaTutor[]
}

model TutorAlumno {
  tutorId  Int
  alumnoId Int
  tutor    Tutor  @relation(fields: [tutorId], references: [id])
  alumno   Alumno @relation(fields: [alumnoId], references: [id])

  @@id([tutorId, alumnoId])
}

// ==========================================
// Relaciones y Módulos Adicionales
// ==========================================

model GrupoDocente {
  id        Int     @id @default(autoincrement())
  grupoId   Int
  docenteId Int
  materiaId Int
  grupo     Grupo   @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  docente   Docente @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  materia   MateriaCatalogo @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  horarios  Horario[]

  @@unique([grupoId, docenteId, materiaId])
}

model Horario {
  id             Int           @id @default(autoincrement())
  grupoDocenteId Int
  grupoDocente   GrupoDocente  @relation(fields: [grupoDocenteId], references: [id], onDelete: Cascade)
  diaSemana      String        // Ej: "Lunes", "Martes"
  horaInicio     String        // Ej: "07:00"
  horaFin        String        // Ej: "08:40"
}

model Asistencia {
  id       Int      @id @default(autoincrement())
  alumnoId Int
  alumno   Alumno   @relation(fields: [alumnoId], references: [id])
  fecha    DateTime
  estado   String // Presente, Ausente, Retardo, Justificado
}

model Calificacion {
  id       Int    @id @default(autoincrement())
  alumnoId Int
  materia  String
  parcial1 Float?
  parcial2 Float?
  parcial3 Float?
  final    Float?
  alumno   Alumno @relation(fields: [alumnoId], references: [id])
}

model Tramite {
  id                     Int      @id @default(autoincrement())
  alumnoId               Int
  alumno                 Alumno   @relation(fields: [alumnoId], references: [id])
  tipo                   String?
  motivo                 String?
  estado                 String   @default("Pendiente")
  estatus                String   @default("Pendiente")
  observaciones          String?
  respuestaAdministrador String?
  creadoEn               DateTime @default(now())
}

model BitacoraAcceso {
  id        Int      @id @default(autoincrement())
  docenteId Int
  docente   Docente  @relation(fields: [docenteId], references: [id])
  tipo      String // Entrada o Salida
  timestamp DateTime @default(now())
}

model MateriaCatalogo {
  id            Int            @id @default(autoincrement())
  nombre        String         @unique
  descripcion   String?
  creditos      Int            @default(0)
  semestre      Int?
  creadoEn      DateTime       @default(now())
  grupoDocentes GrupoDocente[]
}

// ==========================================
// Aula Virtual y Comunicaciones
// ==========================================

model Tarea {
  id               Int       @id @default(autoincrement())
  titulo           String
  descripcion      String?
  materia          String // O relación con MateriaCatalogo
  fechaVencimiento DateTime?

  grupoId Int
  grupo   Grupo @relation(fields: [grupoId], references: [id])

  docenteId Int
  docente   Docente @relation(fields: [docenteId], references: [id])

  entregas      EntregaTarea[]
  creadoEn      DateTime       @default(now())
  actualizadoEn DateTime       @updatedAt
}

model EntregaTarea {
  id      Int   @id @default(autoincrement())
  tareaId Int
  tarea   Tarea @relation(fields: [tareaId], references: [id])

  alumnoId Int
  alumno   Alumno @relation(fields: [alumnoId], references: [id])

  contenido  String? // Texto de la entrega
  archivoUrl String? // Link al archivo (PDF/Doc)

  calificacion      Float?
  retroalimentacion String?

  entregadoEn   DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@unique([tareaId, alumnoId])
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  mensaje   String
  leida     Boolean  @default(false)
  tipo      String // Tarea, Calificacion, Aviso, Tramite
  creadoEn  DateTime @default(now())
}

model CitaTutor {
  id        Int       @id @default(autoincrement())
  tutorId   Int
  alumnoId  Int
  tutor     Tutor     @relation(fields: [tutorId], references: [id])
  alumno    Alumno    @relation(fields: [alumnoId], references: [id])
  motivo    String
  estatus   String    @default("Pendiente") // Pendiente, Aceptada, Rechazada
  fechaHora DateTime?
  creadoEn  DateTime  @default(now())
}
