generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Tu tabla sigue igual
model Usuario {
  id             Int      @id @default(autoincrement())
  nombre         String
  email          String   @unique
  password_hash  String
  tipo_usuario   String   
  google_id      String?  
  apple_id       String?  
  fecha_creacion DateTime @default(now())
}